<ui:FluentWindow x:Class="StepTreeSelectorDemo.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:StepTreeSelectorDemo"
                 xmlns:controls="clr-namespace:Demo.Wpf.Controls.Controls;assembly=Demo.Wpf.Controls"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="Step Tree Selector"
                 Height="560"
                 Width="980"
                 MinHeight="520"
                 MinWidth="860"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#667085" />
        </Style>
    </Window.Resources>

    <Grid x:Name="WindowRoot" Background="#F7F8FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="报警原因配置"
            Icon="{ui:SymbolIcon BranchFork24}" />

        <Grid
            Grid.Row="1"
            Margin="32,20,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,22">
                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="#111827"
                    Text="报警原因逐级选择" />
                <TextBlock
                    Margin="0,8,0,0"
                    FontSize="14"
                    Foreground="#667085"
                    Text="从上到下逐级定位原因，只有叶子节点会作为最终结果写回绑定值。" />
            </StackPanel>

            <Border
                Grid.Row="1"
                Grid.Column="0"
                Padding="22"
                Background="White"
                BorderBrush="#E4E7EC"
                BorderThickness="1"
                CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,18">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock
                                FontSize="17"
                                FontWeight="SemiBold"
                                Foreground="#111827"
                                Text="原因树" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="13"
                                Foreground="#667085"
                                Text="按层级展开并选择最终原因" />
                        </StackPanel>

                        <Border
                            DockPanel.Dock="Right"
                            Padding="10,5"
                            Background="#EEF4FF"
                            CornerRadius="14">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="#3538CD"
                                Text="可复用控件" />
                        </Border>
                    </DockPanel>

                    <local:StepTreeSelector
                        Grid.Row="1"
                        ItemsSource="{Binding ReasonModels}"
                        SelectedItem="{Binding SelectedReason, Mode=TwoWay}"
                        DisplayMemberPath="DisplayName"
                        ChildrenMemberPath="Children"
                        MaintainCommand="{Binding MaintainCommand}"
                        BorderThickness="0"
                        CornerRadius="8"
                        LevelHeaderWidth="72" />
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                Grid.Column="1"
                Margin="18,0,0,0"
                Padding="22"
                Background="White"
                BorderBrush="#E4E7EC"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <Border
                        Width="42"
                        Height="42"
                        HorizontalAlignment="Left"
                        Background="#ECFDF3"
                        CornerRadius="21">
                        <ui:SymbolIcon
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Filled="True"
                            Foreground="#039855"
                            Symbol="CheckmarkCircle12" />
                    </Border>

                    <TextBlock
                        Margin="0,16,0,0"
                        FontSize="17"
                        FontWeight="SemiBold"
                        Foreground="#111827"
                        Text="选择结果" />
                    <TextBlock
                        Margin="0,5,0,0"
                        FontSize="13"
                        Foreground="#667085"
                        Text="当前最终叶子节点" />

                    <Border
                        Margin="0,22,0,0"
                        Padding="14"
                        Background="#F9FAFB"
                        BorderBrush="#EAECF0"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel>
                            <TextBlock
                                Style="{StaticResource SectionLabelStyle}"
                                Text="FINAL REASON" />
                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="#111827"
                                Text="{Binding SelectedReason.DisplayName, TargetNullValue=未选择叶子节点}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Margin="0,14,0,0"
                        Padding="14"
                        Background="#FFFBEB"
                        BorderBrush="#FEDF89"
                        BorderThickness="1"
                        CornerRadius="8">
                        <TextBlock
                            FontSize="13"
                            Foreground="#93370D"
                            TextWrapping="Wrap"
                            Text="选择中间节点只会展开下一层，不会提交为最终原因。" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <controls:OverlayHost
            Grid.RowSpan="2"
            Anchor="{Binding ElementName=WindowRoot}"
            IsOpen="{Binding IsMaintainEditorOpen}"
            OverlayBackground="#99000000">
            <Border
                Width="460"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="#E4E7EC"
                BorderThickness="1"
                CornerRadius="10">
                <Grid x:Name="MaintainEditorRoot">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="#111827"
                        Text="维护子节点" />

                    <TextBlock
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        FontSize="13"
                        Foreground="#667085"
                        Text="{Binding MaintainParent.DisplayName, StringFormat=当前节点：{0}, TargetNullValue=当前节点：根节点}" />

                    <StackPanel Grid.Row="2" Margin="0,22,0,0">
                        <TextBlock
                            Style="{StaticResource SectionLabelStyle}"
                            Text="节点名称" />
                        <TextBox
                            Margin="0,8,0,0"
                            MinHeight="38"
                            Padding="10,7"
                            Text="{Binding MaintainNodeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="3"
                        Margin="0,24,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <ui:Button
                            Margin="0,0,10,0"
                            Appearance="Secondary"
                            Command="{Binding OpenMaintainPreviewCommand}"
                            Content="局部预览" />
                        <ui:Button
                            Margin="0,0,10,0"
                            Appearance="Secondary"
                            Command="{Binding CloseMaintainEditorCommand}"
                            Content="取消" />
                        <ui:Button
                            Appearance="Primary"
                            Command="{Binding SaveMaintainNodeCommand}"
                            Content="保存" />
                    </StackPanel>

                    <controls:OverlayHost
                        Grid.RowSpan="5"
                        Anchor="{Binding ElementName=MaintainEditorRoot}"
                        IsOpen="{Binding IsMaintainPreviewOpen}"
                        OverlayBackground="#88FFFFFF">
                        <Border
                            Width="320"
                            Padding="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="White"
                            BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="#111827"
                                    Text="局部 Overlay" />

                                <TextBlock
                                    Grid.Row="1"
                                    Margin="0,10,0,0"
                                    FontSize="13"
                                    Foreground="#475467"
                                    TextWrapping="Wrap"
                                    Text="{Binding MaintainNodeName, StringFormat=当前输入：{0}, TargetNullValue=当前输入：}" />

                                <ui:Button
                                    Grid.Row="2"
                                    Margin="0,18,0,0"
                                    HorizontalAlignment="Right"
                                    Appearance="Primary"
                                    Command="{Binding CloseMaintainPreviewCommand}"
                                    Content="关闭预览" />
                            </Grid>
                        </Border>
                    </controls:OverlayHost>
                </Grid>
            </Border>
        </controls:OverlayHost>
    </Grid>
</ui:FluentWindow>
