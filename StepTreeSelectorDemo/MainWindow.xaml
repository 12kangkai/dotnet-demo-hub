<Window x:Class="StepTreeSelectorDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StepTreeSelectorDemo"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontSize="18"
            FontWeight="SemiBold"
            Margin="0,0,0,16"
            Text="报警原因逐级选择 Demo" />

        <local:StepTreeSelector
            Grid.Row="1"
            ItemsSource="{Binding ReasonModels}"
            SelectedItem="{Binding SelectedReason, Mode=TwoWay}"
            DisplayMemberPath="DisplayName"
            ChildrenMemberPath="Children"
            MaintainCommand="{Binding MaintainCommand}"
            BorderThickness="1"
            BorderBrush="#999"
            CornerRadius="6" />

        <TextBlock
            Grid.Row="2"
            Margin="0,16,0,0"
            FontSize="16"
            Text="{Binding SelectedReason.DisplayName, StringFormat=最终选择：{0}, TargetNullValue=最终选择：未选择叶子节点}" />
    </Grid>
</Window>
